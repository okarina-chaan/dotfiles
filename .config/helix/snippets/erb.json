{
  "ERB output": {
    "prefix": "erb",
    "body": [
      "<%= ${1} %>"
    ],
    "description": "ERB output tag"
  },

  "ERB if": {
    "prefix": "ifp",
    "body": [
      "<% if ${1:condition} %>",
      "  ${2}",
      "<% end %>"
    ],
    "description": "ERB if block"
  },

  "ERB each": {
    "prefix": "each",
    "body": [
      "<% ${1:collection}.each do |${2:item}| %>",
      "  ${3}",
      "<% end %>"
    ],
    "description": "ERB each block"
  },

  "ERB render": {
    "prefix": "render",
    "body": [
      "<%= render \"${1:partial}\" %>"
    ],
    "description": "Render partial"
  },

  "ERB link_to": {
    "prefix": "link",
    "body": [
      "<%= link_to ${1:\"text\"}, ${2:path} %>"
    ],
    "description": "link_to helper"
  },

  "ERB button_to": {
    "prefix": "button",
    "body": [
      "<%= button_to ${1:\"text\"}, ${2:path}, method: :${3:post} %>"
    ],
    "description": "button_to helper"
  }
}
